{
  "name": "smartbank-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "SmartBank Workspace - Unified E-Wallet & Central Bank CBDC Moneter System",
  "scripts": {
    "start:wallet": "npm --prefix Wallet run dev",
    "start:cb": "npm --prefix Central-Bank run start:dev",
    "start:cb-ui": "npm --prefix Central-Bank run frontend:dev",
    "cb:db-migrate": "npm --prefix Central-Bank run prisma:migrate",
    "cb:db-seed": "npm --prefix Central-Bank run prisma:seed",
    "cb:generate": "npm --prefix Central-Bank run prisma:generate",
    "start:local": "concurrently \"npm:start:cb\" \"npm:start:wallet\" \"npm:start:gateway\" \"npm:start:cb-ui\"",
    "start:gateway": "npm --prefix Gateway run dev"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}